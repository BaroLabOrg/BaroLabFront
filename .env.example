# Backend API base URL (required)
VITE_API_BASE_URL=https://api.barolab.i-lab.ink

# Google OAuth Client ID (required for Google Sign-In)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Public site URL — used for canonical, Open Graph, JSON-LD, sitemap, llms.txt
# Update this when the domain changes
VITE_SITE_URL=https://barolab.i-lab.ink
